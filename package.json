{
  "name": "microsoft-outlook-mcp",
  "version": "0.1.0",
  "description": "MCP server for Microsoft Outlook (Mail, Calendar, Contacts) via Microsoft Graph API with OAuth 2.0 device code flow.",
  "type": "module",
  "bin": {
    "outlook-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "login": "node dist/login.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@azure/msal-node-extensions": "^1.5.32",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
