# ---------------------------------------------------------------------------
# Azure AD app registration values. Copy this file to `.env` and fill in.
# ---------------------------------------------------------------------------

# Application (client) ID from your Azure AD app registration.
OUTLOOK_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Directory (tenant) ID, or one of the well-known values:
#   common         -> any org + personal Microsoft accounts
#   organizations  -> any org (work/school) account
#   consumers      -> personal Microsoft accounts only
#   <tenant-guid>  -> a single specific tenant
OUTLOOK_TENANT_ID=common

# Space-separated delegated Graph scopes the server will request.
# offline_access is added automatically by MSAL for refresh tokens.
OUTLOOK_SCOPES=User.Read Mail.ReadWrite Mail.Send Calendars.ReadWrite Contacts.ReadWrite

# Absolute path for the on-disk MSAL token cache.
# Defaults to `.token-cache.json` next to the server if unset.
# OUTLOOK_TOKEN_CACHE_PATH=C:\Users\you\.outlook-mcp\token-cache.json
